msgid "Troubleshooting"
msgstr ""

#: ../../build123d/docs/tutorial_constraints.rst:799
msgid "Too many results: add qualifiers and a stricter ``selector``."
msgstr ""

#: ../../build123d/docs/tutorial_constraints.rst:801
msgid ""
"No results: relax qualifier (start with ``UNQUALIFIED``) and verify geometry"
" is coplanar."
msgstr ""

#: ../../build123d/docs/tutorial_constraints.rst:803
msgid ""
"Unstable branch selection: avoid index-only selection when topology changes;"
" prefer geometric sorting."
msgstr ""

#: ../../build123d/docs/tutorial_constraints.rst:805
