#: ../../build123d/docs/build_line.rst:3
msgid "BuildLine"
msgstr ""

#: ../../build123d/docs/build_line.rst:5
msgid "BuildLine is a python context manager that is used to create one dimensional objects - objects with the property of length but not area - that are typically used as part of a BuildSketch sketch or a BuildPart path."
msgstr ""

#: ../../build123d/docs/build_line.rst:9
msgid "The complete API for BuildLine is located at the end of this section."
msgstr ""

#: ../../build123d/docs/build_line.rst:13
msgid "Basic Functionality"
msgstr ""

